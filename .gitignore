.DS_Store
biocypher-*
.vscode

# Cluster extraction cache (versioned runs, pre-processing cache)
.extraction_cache/

# Claude Code runtime lock files (regenerated every session)
.claude/scheduled_tasks.lock

# Docker import artifacts (regenerated every rebuild)
/output/import.report
/output/import.status

# Release dumps — never committed. Used only as a fallback in the local-box
# release flow (build-once + volume-copy); see plans/alpha_release.md §6.3.
# metadata.json fragments stay tracked — small and useful audit trail.
/output/releases/*.dump
/output/releases/*.dump.sha256

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# PEP 582; used by e.g. github.com/David-OConnor/pyflow
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/
.idea

# Git worktrees
.worktrees/

# MNX (MetaNetX) reference data is large (~4 GB SQLite) and lives outside the
# checkout — point MNX_DATA_DIR in .env at a central location (e.g. ~/tools/mnx).
# If a stray cache/data/mnx ever appears, ignore it.
cache/data/mnx

# TCDB raw TSVs (re-downloadable by step 6). The committed step-6 outputs
# (tcdb_hierarchy.json, tcdb_pruned.json) sit one level up at cache/data/tcdb/
# and stay tracked.
cache/data/tcdb/raw

# CAZy raw downloads (if any).
cache/data/cazy

# KEGG raw REST response cache (regenerated by kegg_utils.download_kegg_data).
# Excluded from git — repopulated on first run or with --force.
cache/data/kegg/raw

# TCDB-diamond skill: smoke-test artifacts (limited_N runs) are transient.
# Full-run outputs (<strain>.tcdb.{tsv,calls.json,skill_summary.json}) are
# intentionally committed alongside eggnog/ outputs.
cache/data/*/genomes/*/tcdb/*.limited_*


# worktrees
.claude/worktrees

# Run logs and tool-step artifacts (prepare_data step logs, per-tool subdirs,
# .done sentinels, post-import baselines). Transient — regenerated on each run.
logs/
